DEFAULT_BASE_URL=https://api.deepseek.com
PATCH_MODE=replay
REPLAY_MISS_FALLBACK=none
FAKE_REASONING_CONTENT=done
NORMALIZE_DEVELOPER_ROLE=true
NORMALIZE_CONTENT_BLOCKS=true
STRIP_UNSUPPORTED_PARAMS=true
FORCE_MODEL=
CACHE_DB_PATH=/data/reasoning_cache.sqlite3
CACHE_TTL_SECONDS=86400
ALLOWED_BASE_HOSTS=api.deepseek.com
LOG_LEVEL=INFO
